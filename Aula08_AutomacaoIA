        "### Consulta de Endereço via API ViaCEP\n",
        "\n",
        "Este script Python permite consultar informações de endereço utilizando a API pública do ViaCEP. Ele recebe um Código de Endereçamento Postal (CEP) como entrada, faz uma requisição à API e retorna os dados do endereço formatados de maneira legível. É uma ótima forma de demonstrar como interagir com APIs externas."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "19425260"
      },
      "source": [
        "import requests\n",
        "import json\n",
        "\n",
        "def consultar_cep(cep):\n",
        "    \"\"\"\n",
        "    Consulta a API do ViaCEP para obter informações de endereço de um determinado CEP.\n",
        "\n",
        "    Args:\n",
        "        cep (str): O Código de Endereçamento Postal (CEP) a ser consultado (apenas números).\n",
        "\n",
        "    Returns:\n",
        "        str: Uma string formatada com as informações do endereço ou uma mensagem de erro.\n",
        "    \"\"\"\n",
        "    # Remove caracteres não numéricos do CEP para garantir o formato correto\n",
        "    cep = ''.join(filter(str.isdigit, cep))\n",
        "\n",
        "    # Verifica se o CEP possui 8 dígitos\n",
        "    if len(cep) != 8:\n",
        "        return \"Erro: O CEP deve conter 8 dígitos numéricos.\"\n",
        "\n",
        "    # URL da API do ViaCEP\n",
        "    url = f\"https://viacep.com.br/ws/{cep}/json/\"\n",
        "\n",
        "    try:\n",
        "        # Faz a requisição HTTP para a API\n",
        "        response = requests.get(url)\n",
        "        response.raise_for_status()  # Lança uma exceção para códigos de status HTTP de erro (4xx ou 5xx)\n",
        "\n",
        "        # Converte a resposta JSON para um dicionário Python\n",
        "        data = response.json()\n",
        "\n",
        "        # Verifica se a API retornou um erro (por exemplo, CEP não encontrado)\n",
        "        if 'erro' in data and data['erro']:\n",
        "            return f\"Erro: CEP '{cep}' não encontrado.\"\n",
        "\n",
        "        # Formata as informações do endereço de maneira legível\n",
        "        endereco_formatado = (\n",
        "            f\"CEP: {data.get('cep', 'N/A')}\\n\"\n",
        "            f\"Logradouro: {data.get('logradouro', 'N/A')}\\n\"\n",
        "            f\"Complemento: {data.get('complemento', 'N/A')}\\n\"\n",
        "            f\"Bairro: {data.get('bairro', 'N/A')}\\n\"\n",
        "            f\"Localidade: {data.get('localidade', 'N/A')}\\n\"\n",
        "            f\"UF: {data.get('uf', 'N/A')}\\n\"\n",
        "            f\"DDD: {data.get('ddd', 'N/A')}\\n\"\n",
        "            f\"IBGE: {data.get('ibge', 'N/A')}\"\n",
        "        )\n",
        "        return endereco_formatado\n",
        "\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        return f\"Erro de conexão: Não foi possível acessar a API do ViaCEP. Detalhes: {e}\"\n",
        "    except json.JSONDecodeError:\n",
        "        return \"Erro: Não foi possível decodificar a resposta da API como JSON.\"\n",
        "    except Exception as e:\n",
        "        return f\"Ocorreu um erro inesperado: {e}\"\n",
        "\n",
        "# --- Exemplo de Uso --- #\n",
        "cep_exemplo = \"01001000\"  # CEP da Sé, São Paulo\n",
        "print(f\"Consultando CEP: {cep_exemplo}\\n\")\n",
        "resultado = consultar_cep(cep_exemplo)\n",
        "print(resultado)\n",
        "\n",
        "print(\"\\n\" + \"-\"*30 + \"\\n\")\n",
        "\n",
        "cep_invalido = \"99999999\" # Exemplo de CEP inválido (não existe)\n",
        "print(f\"Consultando CEP inválido: {cep_invalido}\\n\")\n",
        "resultado_invalido = consultar_cep(cep_invalido)\n",
        "print(resultado_invalido)\n"
      ],
